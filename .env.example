# Server Configuration
PORT=3000

# Frontend URL Configuration (Used for password recovery links, etc.)
FRONTEND_URL=http://localhost:4200

# Database Configuration
DATABASE_NAME=apicultura.sqlite

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h

# SMTP Configuration (Used when EMAIL_DISABLED=false)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@gmail.com
SMTP_PASS=password

# Email Simulation / Disable Configuration
# Set to 'true' to disable sending actual SMTP emails and log/save them locally instead
EMAIL_DISABLED=true

# Local file where simulated email contents will be written/appended when EMAIL_DISABLED=true
EMAIL_SIMULATION_FILE=simulated_emails.log
